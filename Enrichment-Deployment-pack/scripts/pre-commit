#!/usr/bin/env bash
set -euo pipefail
# AI Code Review pre-commit hook
# Install: cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# Requires: PERPLEXITY_API_KEY in env

if [ -z "${PERPLEXITY_API_KEY:-}" ]; then
    echo "⚠️  PERPLEXITY_API_KEY not set — skipping AI review"
    exit 0
fi

STAGED=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(py|yaml|yml|toml)$' || true)
if [ -z "$STAGED" ]; then
    exit 0
fi

echo "🔍 AI review on $(echo "$STAGED" | wc -l | tr -d ' ') file(s)..."
python scripts/ai_review.py --mode staged --model sonar-pro
