# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Repository Variables & Secrets Template
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Configure these in GitHub → Settings → Secrets and Variables → Actions
# Sibling parity: Cognitive.Engine.Graphs/.github/env.template
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── Project Identity ──────────────────────────────────────────────────────
# PROJECT_NAME=Enrichment.Inference.Engine
# PRIMARY_BRANCH=main
# DEVELOP_BRANCH=develop

# ── Python Configuration ─────────────────────────────────────────────────
# PYTHON_VERSION=3.12
# REQUIREMENTS_FILE=requirements.txt
# COVERAGE_THRESHOLD=60
# TEST_DIR=tests/
# SOURCE_DIR=app

# ── Container Registry ───────────────────────────────────────────────────
# REGISTRY=ghcr.io
# IMAGE_NAME=<auto: github.repository>

# ── Kubernetes / Helm ─────────────────────────────────────────────────────
# HELM_VERSION=3.16.3
# HELM_CHART_PATH=deploy/helm/chart
# HELM_RELEASE_PREFIX=enrichment-engine
# PROD_NAMESPACE=enrichment-prod
# STAGING_NAMESPACE=enrichment-staging
# PROD_REPLICAS=3
# STAGING_REPLICAS=1
# PROD_URL=https://enrichment.example.com
# STAGING_URL=https://staging.enrichment.example.com
# HEALTH_ENDPOINT=/health

# ── Test Services (optional) ─────────────────────────────────────────────
# POSTGRES_IMAGE=postgres:16
# POSTGRES_USER=test_user
# POSTGRES_DB=test_db
# REDIS_IMAGE=redis:7-alpine

# ── PR Policy ─────────────────────────────────────────────────────────────
# PR_WARN_LINES=300
# PR_BLOCK_LINES=1000
# PR_MAX_FILES=50

# ── Supply Chain / Licensing ──────────────────────────────────────────────
# ALLOWED_LICENSES=MIT;BSD;Apache;ISC;PSF;MPL;LGPL;Unlicense;Public Domain
# DENIED_LICENSES=GPL-3.0;AGPL;SSPL;EUPL
# PIP_LICENSES_ALLOW=MIT;BSD;Apache;ISC
# PIP_LICENSES_DENY=GPL-3.0;AGPL-3.0

# ── Notifications (optional) ─────────────────────────────────────────────
# SLACK_NOTIFICATIONS_ENABLED=true

# Telegram — non-CodeRabbit bots (.github/workflows/telegram-pr-review-notify.yml)
# TELEGRAM_BOT_TOKEN            — (secret) same as .env.local
# TELEGRAM_CHAT_ID              — (variable) numeric chat id
# TELEGRAM_REVIEW_NOTIFY_MODE   — (variable) bots | all  (default bots; CodeRabbit excluded in script)
# TELEGRAM_REVIEW_BOT_ALLOWLIST — (variable) optional comma list; overrides default bot logins
# Outbound Telegram text prefixes @QuantumAI_IgorBot (tools/telegram_visibility.py + coderabbit-notify.yml).
# (SonarCloud + GitGuardian workflows: Telegram only when those jobs fail — no extra variables.)

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# SECRETS (configure in GitHub → Settings → Secrets)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# KUBECONFIG          — base64-encoded Kubernetes config
# SLACK_WEBHOOK_URL              — Slack incoming webhook (e.g. k8s-deploy notifications)
# CODECOV_TOKEN       — Codecov upload token
# SONAR_TOKEN         — SonarCloud user token (secret only — see variables below for org/project keys)
# GITGUARDIAN_API_KEY — GitGuardian API key (scan scope) for gitguardian.yml

# SonarQube Cloud (.github/workflows/sonarcloud.yml) — VARIABLES (not secrets):
# SONAR_ORG_KEY       — Organization key from sonarcloud.io (Project Information)
# SONAR_PROJECT_KEY   — Project key from SonarCloud
# Secret: SONAR_TOKEN — Account → Security → generate token
# Until all three are set, the workflow skips with a notice.

# CodeRabbit — no repo secret for core reviews; install the GitHub App + plan at coderabbit.ai
# TELEGRAM_BOT_TOKEN (secret) + TELEGRAM_CHAT_ID (variable) for coderabbit-notify.yml
#   and telegram-pr-review-notify.yml (general bot PR activity)
# Test in GitHub: Actions → "CodeRabbit Review Notify" → Run workflow (workflow_dispatch)

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# BULK UPLOAD (same keys to many repos)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Organization secrets: Org → Settings → Secrets → Actions → Selected repositories
# CLI: gh secret set -f .env.local -R owner/repo   or  tools/sync_github_actions_secrets.sh

