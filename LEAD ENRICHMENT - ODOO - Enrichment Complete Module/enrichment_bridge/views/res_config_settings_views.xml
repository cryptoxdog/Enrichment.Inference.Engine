<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_enrichment" model="ir.ui.view">
        <field name="name">res.config.settings.enrichment</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@string='General Settings']" position="inside">
                <block title="Enrichment API" name="enrichment_settings">
                    <setting string="API Configuration"
                             help="Configure the connection to the Enrichment API service.">
                        <div class="content-group">
                            <div class="row mt16">
                                <label for="enrichment_api_url" class="col-lg-3"/>
                                <field name="enrichment_api_url" class="col-lg-9"/>
                            </div>
                            <div class="row mt8">
                                <label for="enrichment_api_key" class="col-lg-3"/>
                                <field name="enrichment_api_key" class="col-lg-9"
                                       password="True"/>
                            </div>
                            <div class="row mt8">
                                <label for="enrichment_batch_size" class="col-lg-3"/>
                                <field name="enrichment_batch_size" class="col-lg-9"/>
                            </div>
                        </div>
                    </setting>
                    <setting string="Auto-Enrich"
                             help="Automatically enrich new leads every 4 hours via cron.">
                        <field name="enrichment_auto_enrich"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
