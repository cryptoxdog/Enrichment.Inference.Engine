<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="enrichment_run_tree" model="ir.ui.view">
        <field name="name">enrichment.run.tree</field>
        <field name="model">enrichment.run</field>
        <field name="arch" type="xml">
            <tree decoration-success="state == 'completed'"
                  decoration-danger="state == 'failed'"
                  decoration-info="state == 'pending'">
                <field name="create_date"/>
                <field name="res_model"/>
                <field name="res_id"/>
                <field name="state"/>
                <field name="confidence" widget="progressbar"/>
                <field name="fields_enriched"/>
                <field name="tokens_used"/>
                <field name="processing_time_ms"/>
                <field name="inference_version"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="enrichment_run_form" model="ir.ui.view">
        <field name="name">enrichment.run.form</field>
        <field name="model">enrichment.run</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group string="Source">
                            <field name="res_model"/>
                            <field name="res_id"/>
                            <field name="idempotency_key"/>
                            <button name="action_view_source_record"
                                    string="Open Record"
                                    type="object"
                                    class="oe_link"/>
                        </group>
                        <group string="Results">
                            <field name="confidence" widget="progressbar"/>
                            <field name="fields_enriched"/>
                            <field name="failure_reason"
                                   invisible="state != 'failed'"/>
                        </group>
                    </group>
                    <group string="Provenance">
                        <group>
                            <field name="variation_count"/>
                            <field name="consensus_threshold"/>
                            <field name="kb_content_hash"/>
                        </group>
                        <group>
                            <field name="inference_version"/>
                            <field name="tokens_used"/>
                            <field name="processing_time_ms"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Enriched Data">
                            <field name="enriched_data"/>
                        </page>
                        <page string="Raw Response">
                            <field name="raw_response"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_enrichment_run" model="ir.actions.act_window">
        <field name="name">Enrichment Runs</field>
        <field name="res_model">enrichment.run</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{"search_default_state": "completed"}</field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_enrichment_root"
              name="Enrichment"
              sequence="90"/>
    <menuitem id="menu_enrichment_runs"
              name="Enrichment Runs"
              parent="menu_enrichment_root"
              action="action_enrichment_run"
              sequence="10"/>
</odoo>
