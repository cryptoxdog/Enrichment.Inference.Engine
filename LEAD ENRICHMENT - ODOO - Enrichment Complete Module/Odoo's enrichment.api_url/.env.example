# Enrichment API v2.2 — Environment Variables
# Copy to .env and fill in real values

# ── Required ─────────────────────────────────────
PERPLEXITY_API_KEY=pplx-YOUR-KEY-HERE
API_SECRET_KEY=generate-with-openssl-rand-hex-32
API_KEY_HASH=sha256-hash-of-your-client-api-key

# ── Optional (defaults shown) ────────────────────
LOG_LEVEL=INFO
PERPLEXITY_MODEL=sonar-reasoning
DEFAULT_CONSENSUS_THRESHOLD=0.65
DEFAULT_MAX_VARIATIONS=5
DEFAULT_TIMEOUT_SECONDS=120
MAX_CONCURRENT_VARIATIONS=3
MAX_ENTITIES_PER_BATCH=50
CB_FAILURE_THRESHOLD=5
CB_COOLDOWN_SECONDS=60
REDIS_URL=redis://localhost:6379/0
KB_DIR=/app/kb
