<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_kb_import_wizard_form" model="ir.ui.view">
        <field name="name">plasticos.polymer.kb.import.wizard.form</field>
        <field name="model">plasticos.polymer.kb.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Polymer KB">
                <group>
                    <field name="yaml_file" filename="filename"/>
                    <field name="filename" invisible="1"/>
                </group>
                <footer>
                    <button name="action_import" string="Import"
                            type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_kb_import_wizard" model="ir.actions.act_window">
        <field name="name">Import Polymer KB</field>
        <field name="res_model">plasticos.polymer.kb.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
