# ─────────────────────────────────────────────────────────────
# L9 ENRICH — Environment Template
# Copy to .env and fill in real values. NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# ── Auth ──────────────────────────────────────────────────────
ENRICH_API_KEY=your-api-key-here

# ── LLM Providers ─────────────────────────────────────────────
PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# ── Graph Layer ───────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# ── Persistence ───────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://enrich:changeme@localhost:5432/enrich
REDIS_URL=redis://localhost:6379/0

# ── Constellation Node URLs ───────────────────────────────────
GRAPH_NODE_URL=http://graph-service:8001
SCORE_NODE_URL=http://score-service:8002
ROUTE_NODE_URL=http://route-service:8003
INTER_NODE_SECRET=changeme-inter-node-secret

# ── Domain Config ─────────────────────────────────────────────
DOMAINS_DIR=./domains
DEFAULT_DOMAIN=plasticos

# ── App Config ────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development
PORT=8000
WORKERS=4
MAX_BUDGET_TOKENS_DEFAULT=50000
TOKEN_RATE_USD_PER_1K=0.005
