"""
Scoring assembler for {{ schema.name }}.
Translates scoring dimensions from spec.yaml → Cypher WITH / RETURN clauses.
Auto-generated — DO NOT EDIT.
"""
from __future__ import annotations

SCORING_DIMENSIONS = [
    {% for dim in schema.scoring.dimensions %}
    {
        "name":   "{{ dim.name }}",
        "field":  "{{ dim.field }}",
        "weight": {{ dim.weight }},
        "direction": "{{ dim.direction | default("higher_is_better") }}",
    },
    {% endfor %}
]

TOTAL_WEIGHT = sum(d["weight"] for d in SCORING_DIMENSIONS)


def assemble_scoring_cypher(prefix: str = "candidate") -> str:
    """
    Build Cypher WITH clause that computes a weighted composite score.
    Returns clause fragment to append after gate filtering.
    """
    dim_scores = []
    for dim in SCORING_DIMENSIONS:
        field   = f"{prefix}.{dim['field']}"
        weight  = dim["weight"] / TOTAL_WEIGHT
        if dim["direction"] == "lower_is_better":
            expr = f"(1.0 - coalesce({field}, 0.5)) * {weight:.4f}"
        else:
            expr = f"coalesce({field}, 0.5) * {weight:.4f}"
        dim_scores.append(f"({expr}) /* {dim['name']} */")

    score_expr = " + ".join(dim_scores)
    return (
        f"WITH {prefix},\n"
        f"     ({score_expr}) AS composite_score"
    )
