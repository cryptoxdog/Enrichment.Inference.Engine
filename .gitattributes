# Line ending normalization
* text=auto eol=lf
*.py text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.sh text eol=lf

# Binary files — no diffing
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary

# Model weights — Git LFS
*.bin filter=lfs diff=lfs merge=lfs -text
*.pt filter=lfs diff=lfs merge=lfs -text
*.safetensors filter=lfs diff=lfs merge=lfs -text
*.gguf filter=lfs diff=lfs merge=lfs -text

# Linguist — keep YAML spec files out of language stats
meta_ir/**/*.yaml linguist-documentation=true
domains/**/*.yaml linguist-documentation=true
