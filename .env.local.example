# =============================================================================
# Local secrets only — copy to .env.local and fill in (DO NOT COMMIT)
# =============================================================================
# Loaded after .env by app/core/config.py (pydantic-settings). .env.local overrides .env.
#
# GitHub Actions: create secrets under the SAME names (Settings → Secrets → Actions).
# Copy values from this file into each repo (or use one org-level secret per name).
#
# See: docs/contracts/config/env-contract.yaml → github_actions
#      .github/env.template

# --- CI / PR review (workflows reference these exact names) ---
PERPLEXITY_API_KEY=
TELEGRAM_BOT_TOKEN=

# --- Deploy (k8s-deploy workflow) — not app Settings env vars ---
# KUBECONFIG=          # paste base64 kubeconfig in GitHub secret only; rarely needed locally
# SLACK_WEBHOOK_URL=

# --- Optional CI ---
# CODECOV_TOKEN=

# --- Runtime secrets (same names as GitHub if you inject into deploy jobs) ---
# API_SECRET_KEY=
# ENRICHMENT_ENGINE_API_KEY=
# DATABASE_URL=
# NEO4J_PASSWORD=
# INTER_NODE_SECRET=
# ODOO_PASSWORD=
# ODOO_API_KEY=
# SALESFORCE_CLIENT_SECRET=
# SALESFORCE_PASSWORD=
# SALESFORCE_SECURITY_TOKEN=
# HUBSPOT_ACCESS_TOKEN=
# CLEARBIT_API_KEY=
# ZOOMINFO_API_KEY=
# APOLLO_API_KEY=
# HUNTER_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# --- Repository VARIABLE (not a secret) — set in GitHub → Variables → Actions ---
# TELEGRAM_CHAT_ID=   # used with TELEGRAM_BOT_TOKEN for coderabbit-notify.yml
