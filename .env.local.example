# =============================================================================
# .env.local — copy to .env.local and fill values (gitignored)
# =============================================================================
# Loaded after .env. Names = GitHub Actions secret names when you sync with gh/tools.
#
# You already have 3 API keys — likely include PERPLEXITY_* plus two CRM/LLM keys below.
# Add any other lines you need; leave unused lines blank or commented.

# --- Required for normal engine startup (see env-contract required_for_startup) ---
PERPLEXITY_API_KEY=
API_SECRET_KEY=

# --- Client auth (hash of the key callers send as X-API-Key / bearer, if you use it) ---
API_KEY_HASH=

# --- Optional: GitHub Actions / CI (sync these names to repo secrets if you use the workflows) ---
TELEGRAM_BOT_TOKEN=
CODECOV_TOKEN=
SLACK_WEBHOOK_URL=
# KUBECONFIG is usually GitHub-only (base64); rarely needed in .env.local

# --- Caching & persistence (override defaults if not using local docker URLs) ---
REDIS_URL=
DATABASE_URL=

# --- Graph ---
NEO4J_PASSWORD=
# NEO4J_URI=
# NEO4J_USER=

# --- Node-to-node / constellation ---
INTER_NODE_SECRET=

# --- CRM / enrichment sources (add only what you use) ---
ODOO_PASSWORD=
ODOO_API_KEY=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_PASSWORD=
SALESFORCE_SECURITY_TOKEN=
HUBSPOT_ACCESS_TOKEN=
CLEARBIT_API_KEY=
ZOOMINFO_API_KEY=
APOLLO_API_KEY=
HUNTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=


# --- Telegram PR review notify (optional filters; token/chat same as coderabbit-notify) ---
# TELEGRAM_REVIEW_NOTIFY_MODE=bots
# TELEGRAM_REVIEW_BOT_ALLOWLIST=
# SLACK_WEBHOOK_URL=
