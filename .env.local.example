# =============================================================================
# .env.local — copy to .env.local and fill values (gitignored)
# =============================================================================
# Loaded after `.env` (see app/core/config.py). Use for machine-specific secrets.
#
# Minimal set for core + Perplexity + Odoo. Prefer gate/SDK for new platform
# integrations; optional CRM/waterfall keys are not listed — add from
# docs/contracts/config/env-contract.yaml only if you use legacy direct paths.

# --- Startup / enrichment ---
PERPLEXITY_API_KEY=
API_KEY_HASH=

# --- Odoo ---
ODOO_URL=
ODOO_DB=
ODOO_USERNAME=
ODOO_PASSWORD=

# --- Optional: LLMs ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Optional: infra overrides ---
REDIS_URL=
DATABASE_URL=
NEO4J_PASSWORD=
INTER_NODE_SECRET=

# --- Optional: GitHub Actions sync (same names as repo secrets) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
