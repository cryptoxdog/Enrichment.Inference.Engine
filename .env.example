# =============================================================================
# Enrichment Inference Engine — minimal .env template
# =============================================================================
# Copy to `.env` and/or `.env.local` (local overrides). Do not commit real secrets.
#
# This file lists only what you typically need for core engine + Perplexity + Odoo.
# New integrations with other platforms should go through the gate/SDK (chassis /
# PacketEnvelope), not new env keys here. Optional Salesforce, HubSpot, waterfall
# keys are NOT listed — add from docs/contracts/config/env-contract.yaml only if you
# still use legacy direct clients.

# --- Logging ---
LOG_LEVEL=INFO

# --- Perplexity (primary enrichment) ---
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar-reasoning

# --- API auth (client sends raw key; server compares SHA-256 to API_KEY_HASH) ---
API_SECRET_KEY=
API_KEY_HASH=

# --- Knowledge base & Redis ---
KB_DIR=/app/kb
REDIS_URL=redis://localhost:6379/0

# --- Odoo CRM (only CRM block in this template) ---
ODOO_URL=
ODOO_DB=
ODOO_USERNAME=
ODOO_PASSWORD=
CRM_MAPPING_PATH=config/crm/odoo_mapping.yaml

# --- Optional LLMs (enable when you wire OpenAI / Anthropic clients) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Persistence, graph, domain packs (override defaults for non-local deploys) ---
DATABASE_URL=postgresql+asyncpg://enrich:changeme@localhost:5432/enrich
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
DOMAINS_DIR=./domains
DEFAULT_DOMAIN=plasticos

# --- Constellation / sibling node URLs ---
CEG_BASE_URL=http://localhost:8001
GRAPH_NODE_URL=http://localhost:8001
SCORE_NODE_URL=http://localhost:8002
ROUTE_NODE_URL=http://localhost:8003
INTER_NODE_SECRET=dev-inter-node-secret
