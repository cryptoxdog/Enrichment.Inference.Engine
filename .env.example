# =============================================================================
# Enrichment Inference Engine — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# --- Core ---
APP_ENV=development
LOG_LEVEL=INFO

# --- Perplexity Sonar (primary enrichment source) ---
PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxxxxxxxx
PERPLEXITY_MODEL=sonar-reasoning

# --- API Authentication ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
# Hash for storage: python -c "import hashlib; print(hashlib.sha256(b'YOUR_KEY').hexdigest())"
API_SECRET_KEY=change-me-min-32-chars
API_KEY_HASH=sha256-of-client-api-key

# --- Knowledge Base ---
KB_DIR=/app/kb

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Enrichment Defaults ---
DEFAULT_CONSENSUS_THRESHOLD=0.65
DEFAULT_MAX_VARIATIONS=5
DEFAULT_TIMEOUT_SECONDS=120
MAX_CONCURRENT_VARIATIONS=3
MAX_ENTITIES_PER_BATCH=50

# --- Circuit Breaker ---
CB_FAILURE_THRESHOLD=5
CB_COOLDOWN_SECONDS=60

# --- Odoo CRM (first consumer) ---
ODOO_URL=https://your-instance.odoo.com
ODOO_DB=your-database
ODOO_USER=admin
ODOO_PASSWORD=your-password

# --- Salesforce CRM ---
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_USERNAME=
SALESFORCE_PASSWORD=
SALESFORCE_SECURITY_TOKEN=

# --- HubSpot CRM ---
HUBSPOT_ACCESS_TOKEN=

# --- Enrichment Sources (waterfall providers) ---
CLEARBIT_API_KEY=
ZOOMINFO_API_KEY=
APOLLO_API_KEY=
HUNTER_API_KEY=

# --- Cognitive Engine Graphs (sibling node) ---
CEG_BASE_URL=http://localhost:8001
