# =============================================================================
# Enrichment Inference Engine — Environment Configuration
# =============================================================================
# Copy to `.env` for production or `.env.local` for local overrides.
# DO NOT commit real secrets to version control.
#
# USAGE:
#   Local development:  cp .env.example .env && edit values
#   Docker Compose:     docker compose -f docker-compose.prod.yml up -d
#
# VARIABLE NAMING: All L9 engine vars should use L9_ prefix per ENV_VARS.md
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# DOCKER COMPOSE SETTINGS
# ─────────────────────────────────────────────────────────────────────────────
# These are used by docker-compose.prod.yml for container naming and ports

COMPOSE_PROJECT_NAME=eie
APP_PORT=8000

# PostgreSQL (used by postgres service in docker-compose)
POSTGRES_USER=enrich
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=enrich

# Grafana (used by grafana service in docker-compose)
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_in_production
GRAFANA_ROOT_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# APPLICATION SETTINGS
# ─────────────────────────────────────────────────────────────────────────────

# App environment
APP_ENV=production
LOG_LEVEL=INFO

# API Authentication
# Client sends raw key; server compares SHA-256 hash to API_KEY_HASH
API_SECRET_KEY=
API_KEY_HASH=

# Knowledge Base
KB_DIR=/app/kb

# Domain Configuration
DOMAINS_DIR=./domains
DEFAULT_DOMAIN=plasticos

# ─────────────────────────────────────────────────────────────────────────────
# INFRASTRUCTURE CONNECTIONS
# ─────────────────────────────────────────────────────────────────────────────
# NOTE: When running in Docker Compose, these are OVERRIDDEN by the compose file
# to use container networking (e.g., redis://redis:6379 instead of localhost)

# Redis (caching, idempotency, rate limiting)
REDIS_URL=redis://localhost:6379/0

# PostgreSQL (persistence, audit trail)
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://enrich:changeme@localhost:5432/enrich

# Neo4j (graph sync with CEG - optional)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ─────────────────────────────────────────────────────────────────────────────
# LLM PROVIDERS (at least one required for enrichment)
# ─────────────────────────────────────────────────────────────────────────────

# Perplexity (PRIMARY - required for SONAR enrichment)
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar-reasoning

# OpenAI (optional - fallback or specific use cases)
OPENAI_API_KEY=

# Anthropic (optional - fallback or specific use cases)
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# CRM INTEGRATIONS (optional - for writeback action)
# ─────────────────────────────────────────────────────────────────────────────

# Odoo CRM
ODOO_URL=
ODOO_DB=
ODOO_USERNAME=
ODOO_PASSWORD=
CRM_MAPPING_PATH=config/crm/odoo_mapping.yaml

# ─────────────────────────────────────────────────────────────────────────────
# L9 CONSTELLATION (inter-node communication)
# ─────────────────────────────────────────────────────────────────────────────
# URLs for sibling nodes in the L9 constellation
# Inter-node calls use TransportPacket via Gate / POST /v1/execute (SDK runtime)

GATE_URL=http://localhost:8080
CEG_BASE_URL=http://localhost:8001
GRAPH_NODE_URL=http://localhost:8001
SCORE_NODE_URL=http://localhost:8002
ROUTE_NODE_URL=http://localhost:8003

# Shared secret for inter-node authentication
INTER_NODE_SECRET=dev-inter-node-secret

# ─────────────────────────────────────────────────────────────────────────────
# OBSERVABILITY (auto-configured in Docker Compose)
# ─────────────────────────────────────────────────────────────────────────────
# These are set automatically by docker-compose.prod.yml when using the
# monitoring stack. Only set manually for external observability backends.

# OpenTelemetry (traces + metrics)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
# OTEL_SERVICE_NAME=enrichment-engine
# OTEL_RESOURCE_ATTRIBUTES=deployment.environment=production

# ─────────────────────────────────────────────────────────────────────────────
# FEATURE FLAGS
# ─────────────────────────────────────────────────────────────────────────────

# Enable/disable specific features
# L9_ENABLE_GRAPH_SYNC=true
# L9_ENABLE_WRITEBACK=true
# L9_ENABLE_BATCH_ENRICHMENT=true
