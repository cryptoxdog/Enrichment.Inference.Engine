{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/cryptoxdog/Enrichment.Inference.Engine/docs/contracts/data/models/field-confidence-history.schema.json",
  "title": "FieldConfidenceHistory",
  "description": "Time-series per-field confidence values across enrichment passes. Enables the GET /api/v1/fields/{entity_id}/{field}/history endpoint. Table: field_confidence_history. Source: app/services/pg_models.py:137",
  "type": "object",
  "properties": {
    "id": { "type": "string", "format": "uuid", "description": "Primary key." },
    "enrichment_result_id": { "type": "string", "format": "uuid", "description": "FK → enrichment_results.id (ON DELETE CASCADE)." },
    "tenant_id": { "type": "string", "maxLength": 128, "description": "Tenant identifier." },
    "entity_id": { "type": "string", "maxLength": 256, "description": "Entity identifier from CRM." },
    "field_name": { "type": "string", "maxLength": 256, "description": "Name of the field being tracked." },
    "field_value": { "type": ["string", "null"], "description": "Serialized field value at this point in time." },
    "confidence": { "type": "number", "description": "NUMERIC(5,4) confidence score for this field at this pass." },
    "source": { "type": "string", "maxLength": 32, "description": "Data source (enrichment, inference, crm)." },
    "pass_number": { "type": "integer", "description": "Convergence pass number that produced this entry." },
    "variation_agreement": { "type": ["number", "null"], "description": "Fraction of prompt variations that agreed on this value. NUMERIC(5,4)." },
    "recorded_at": { "type": "string", "format": "date-time", "description": "server_default=func.now()." }
  },
  "required": ["id", "enrichment_result_id", "tenant_id", "entity_id", "field_name", "confidence", "source", "pass_number", "recorded_at"],
  "additionalProperties": false,
  "x-storage": "postgresql",
  "x-table": "field_confidence_history",
  "x-indexes": [
    { "name": "ix_field_confidence_entity_field", "columns": ["tenant_id", "entity_id", "field_name"] },
    { "name": "ix_field_confidence_result_pass", "columns": ["enrichment_result_id", "pass_number"] }
  ],
  "x-source-file": "app/services/pg_models.py:137",
